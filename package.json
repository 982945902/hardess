{
  "name": "hardess",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/runtime/server.ts",
    "check": "tsc --noEmit",
    "test": "bun test src/runtime src/sdk src/shared src/load",
    "test:runtime": "bun test src/runtime src/shared",
    "test:sdk": "bun test src/sdk",
    "test:shared": "bun test src/shared",
    "test:load": "bun test src/load",
    "verify": "bun run check && bun run test",
    "clean": "bun run clean:runtime-artifacts",
    "clean:runtime-artifacts": "rm -f config/.*.hardess-config-*.ts workers/.*.hardess-worker-*.ts",
    "demo:upstream": "bun run src/demo/upstream.ts",
    "demo:admin": "bun run src/demo/admin-mock.ts",
    "demo:client": "bun run src/demo/client.ts",
    "demo:http": "bun run src/demo/http-smoke.ts",
    "load:http": "bun run src/load/http.ts",
    "load:http:close": "HTTP_LOAD_CONNECTION_MODE=close bun run src/load/http.ts",
    "load:ws": "bun run src/load/ws.ts",
    "load:cluster-ws": "bun run src/load/cluster-ws.ts",
    "smoke:local": "bash scripts/local-release-smoke.sh",
    "bench:ws": "bun run src/load/benchmark-ws.ts",
    "bench:ws:local": "BENCH_WS_PROFILE=high BENCH_WS_SLO_PROFILE=local bun run src/load/benchmark-ws.ts",
    "bench:ws:high": "BENCH_WS_PROFILE=high bun run src/load/benchmark-ws.ts",
    "bench:cluster": "bun run src/load/benchmark-cluster.ts",
    "bench:cluster:local": "BENCH_CLUSTER_PROFILE=high BENCH_CLUSTER_SLO_PROFILE=local bun run src/load/benchmark-cluster.ts",
    "bench:cluster:high": "BENCH_CLUSTER_PROFILE=high bun run src/load/benchmark-cluster.ts",
    "release:gate:local": "RELEASE_GATE_SLO_PROFILE=local bun run src/load/release-gate.ts",
    "release:gate:cluster:high": "CLUSTER_RELEASE_GATE_PROFILE=high bun run src/load/release-gate-cluster.ts",
    "load:toxiproxy": "bun run src/load/toxiproxy.ts",
    "release:gate": "bun run src/load/release-gate.ts",
    "release:gate:cluster": "bun run src/load/release-gate-cluster.ts",
    "release:gate:cluster:local": "CLUSTER_RELEASE_GATE_SLO_PROFILE=local bun run src/load/release-gate-cluster.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
