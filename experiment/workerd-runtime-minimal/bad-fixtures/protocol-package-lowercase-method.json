{
  "packageId": "workerd-http-ingress@v1",
  "protocol": "workerd-http-ingress",
  "version": "v1",
  "actions": [
    {
      "actionId": "http.info",
      "kind": "http",
      "methods": [
        "get"
      ]
    },
    {
      "actionId": "http.echo",
      "kind": "http",
      "methods": [
        "POST"
      ]
    },
    {
      "actionId": "ws.echo",
      "kind": "websocket",
      "methods": [
        "GET"
      ],
      "websocket": true
    }
  ]
}
